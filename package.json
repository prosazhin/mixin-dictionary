{
  "name": "mixin-dictionary",
  "version": "1.2.2",
  "description": "Creating mixins from design tokens for LESS and SCSS.",
  "license": "MIT",
  "author": "Evgenii Sazhin <prosazhin@gmail.com> (https://prosazhin.ru)",
  "keywords": [
    "mixin dictionary",
    "mixin",
    "style dictionary",
    "style",
    "dictionary",
    "css",
    "less",
    "scss",
    "design",
    "tokens",
    "tool",
    "system",
    "design-tokens",
    "design-tool",
    "design-system"
  ],
  "homepage": "https://github.com/prosazhin/mixin-dictionary",
  "repository": {
    "type": "git",
    "url": "https://github.com/prosazhin/mixin-dictionary.git"
  },
  "bugs": {
    "url": "https://github.com/prosazhin/mixin-dictionary/issues"
  },
  "bin": {
    "mixin-dictionary": "./bin/mixin-dictionary.js"
  },
  "type": "module",
  "engines": {
    "node": ">=20.22.0"
  },
  "files": [
    "bin",
    "lib",
    "README.md"
  ],
  "scripts": {
    "lint": "eslint",
    "format": "prettier --write \"**/*.{js,json}\"",
    "prepare": "npx simple-git-hooks"
  },
  "simple-git-hooks": {
    "pre-commit": "npx --no-install lint-staged --concurrent false",
    "pre-push": "npm run format",
    "commit-msg": "npx --no-install commitlint --edit ${1}"
  },
  "lint-staged": {
    "*.{js,json}": "prettier --write",
    "*.js": "eslint --cache --fix"
  },
  "commitlint": {
    "extends": [
      "@commitlint/config-conventional"
    ]
  },
  "publishConfig": {
    "registry": "https://registry.npmjs.org/"
  },
  "overrides": {
    "brace-expansion": "^5.0.5",
    "flatted": "^3.4.2"
  },
  "devDependencies": {
    "@commitlint/cli": "^20.5.0",
    "@commitlint/config-conventional": "^20.5.0",
    "chalk": "^5.6.2",
    "commander": "^14.0.3",
    "eslint": "^10.1.0",
    "eslint-config-prettier": "^10.1.8",
    "lint-staged": "^16.4.0",
    "prettier": "^3.8.1",
    "simple-git-hooks": "^2.13.1",
    "typescript": "^5.9.3"
  },
  "dependencies": {
    "fs-extra": "^11.3.4",
    "style-dictionary": "^5.4.0"
  }
}
